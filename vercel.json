{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/book$", "dest": "/book.html" },
    { "src": "^/certificate$", "dest": "/certificate.html" },
    { "src": "^/intro-3d$", "dest": "/intro-3d.html" },
    { "src": "^/main$", "dest": "/main.html" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
